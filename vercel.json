{
  "buildCommand": "rm -rf node_modules/.cache && yarn generate",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/_nuxt/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!_nuxt).*)\\.(html|htm)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/_nuxt/(.*)",
      "dest": "/_nuxt/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/200.html"
    }
  ]
}
